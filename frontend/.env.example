# Browser / build: leave empty when UI is served behind nginx that proxies /api and /hubs to omni-api.
OMNI_API_BASE_URL=

# Optional: full SignalR hub URL (must include /hubs/... if you set a host).
# Leave unset to use same-origin /hubs/omni (Vite + nginx proxy WebSockets). Do NOT set this to
# OMNI_API_BASE_URL alone — that breaks WebSockets from the dev server (cross-origin).
# OMNI_SIGNALR_URL=http://localhost:8080/hubs/omni
OMNI_SIGNALR_HUB_PATH=/hubs/omni

# Vite dev only: where to proxy /api, /hubs, /health
OMNI_DEV_API_PROXY_TARGET=http://localhost:8080

# Live preview / camera detail — MediaMTX defaults (browser → host)
# HLS playlist base (port 8888)
OMNI_MEDIA_BASE_URL=http://localhost:8888
# WHEP / WebRTC base (port 8889). If unset, UI derives same host as OMNI_MEDIA_BASE_URL with port 8889.
# OMNI_MEDIA_WEBRTC_BASE_URL=http://localhost:8889

# Optional MJPEG stream (server-side drawn overlays)
OMNI_STREAM_URL=http://localhost:8090/stream
