# Browser / build: leave empty when UI is served behind nginx that proxies /api and /hubs to omni-api.
OMNI_API_BASE_URL=

# SignalR hub path (same host as UI when using compose + nginx proxy).
OMNI_SIGNALR_HUB_PATH=/hubs/omni

# Vite dev only: where to proxy /api, /hubs, /health
OMNI_DEV_API_PROXY_TARGET=http://localhost:8080
