# OmniVision — copy to .env and fill in values

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=omnivision

# -----------------------------------------------------------------------------
# Redis (event bus)
# -----------------------------------------------------------------------------
OMNI_REDIS_URL=redis://omni-bus:6379

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# Docker Compose service: omni-minio
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=omniminioadmin
MINIO_ROOT_PASSWORD=change_this_minio_secret
# Host ports (host machine)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Used by app services (inside Docker network)
OMNI_S3_ENDPOINT=http://omni-minio:9000
# Browser or external clients (optional; dev default)
OMNI_S3_PUBLIC_BASE_URL=http://localhost:9000
OMNI_S3_BUCKET=omni-assets
OMNI_S3_REGION=us-east-1
OMNI_S3_USE_SSL=false
# Often same as MINIO_ROOT_* for dev; use dedicated IAM-style keys in production
OMNI_S3_ACCESS_KEY=
OMNI_S3_SECRET_KEY=

# -----------------------------------------------------------------------------
# Inference / runtime
# -----------------------------------------------------------------------------
OMNI_DEVICE=cuda:0
OMNI_TIMEZONE=Asia/Ho_Chi_Minh
OMNI_CAPTURE_FPS=12
OMNI_LOG_LEVEL=INFO

# Service-to-service auth (rotate in production)
OMNI_INTERNAL_SECRET=changeme

# Paths inside containers (override if compose volumes differ)
OMNI_WEIGHTS_DIR=/app/weights
OMNI_THUMBNAILS_DIR=/app/thumbnails
OMNI_VIDEOS_DIR=/videos

# -----------------------------------------------------------------------------
# Integrations (keep server-side only; do not expose to frontend build)
# -----------------------------------------------------------------------------
OMNI_AGORA_APP_ID=
OMNI_AGORA_APP_CERTIFICATE=

OMNI_ELEVENLABS_API_KEY=

# Qwen: often Alibaba DashScope
OMNI_QWEN_API_KEY=
OMNI_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

OMNI_MANUS_API_KEY=
OMNI_MANUS_BASE_URL=

# -----------------------------------------------------------------------------
# Host Ports (Exposed to host machine)
# -----------------------------------------------------------------------------
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8080
SIMULATOR_PORT=8554
OBJECT_PORT=8555
VEHICLE_PORT=8001
HUMAN_PORT=8002
UI_PORT=3000

