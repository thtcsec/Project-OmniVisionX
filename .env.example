# OmniVision — copy to .env and fill in values

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=omnivision

# -----------------------------------------------------------------------------
# Redis (event bus)
# -----------------------------------------------------------------------------
OMNI_REDIS_URL=redis://omni-bus:6379

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# Docker Compose service: omni-minio
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=omniminioadmin
MINIO_ROOT_PASSWORD=change_this_minio_secret
# Host ports (host machine)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Used by app services (inside Docker network)
OMNI_S3_ENDPOINT=http://omni-minio:9000
# Browser or external clients (optional; dev default)
OMNI_S3_PUBLIC_BASE_URL=http://localhost:9000
OMNI_S3_BUCKET=omni-assets
OMNI_S3_REGION=us-east-1
OMNI_S3_USE_SSL=false
# Often same as MINIO_ROOT_* for dev; use dedicated IAM-style keys in production
OMNI_S3_ACCESS_KEY=
OMNI_S3_SECRET_KEY=

# -----------------------------------------------------------------------------
# Inference / runtime
# -----------------------------------------------------------------------------
OMNI_DEVICE=cuda:0
OMNI_TIMEZONE=Asia/Ho_Chi_Minh
OMNI_CAPTURE_FPS=12
OMNI_LOG_LEVEL=INFO

# Service-to-service auth (rotate in production)
OMNI_INTERNAL_SECRET=changeme

# Paths inside containers (override if compose volumes differ)
OMNI_WEIGHTS_DIR=/app/weights
OMNI_THUMBNAILS_DIR=/app/thumbnails
OMNI_VIDEOS_DIR=/videos

# -----------------------------------------------------------------------------
# Integrations (keep server-side only; do not expose to frontend build)
# -----------------------------------------------------------------------------
OMNI_AGORA_APP_ID=
OMNI_AGORA_APP_CERTIFICATE=

OMNI_ELEVENLABS_API_KEY=

# Qwen: often Alibaba DashScope
OMNI_QWEN_API_KEY=
OMNI_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

OMNI_MANUS_API_KEY=
OMNI_MANUS_BASE_URL=

# -----------------------------------------------------------------------------
# MediaMTX (RTSP → HLS / WebRTC) — service: omni-mediamtx
# HLS :8888, WebRTC/WHEP :8889, API :8997, RTSP relay :18554→8554 in container
# -----------------------------------------------------------------------------
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_API_PORT=8997
MEDIAMTX_RTSP_PORT=18554

# -----------------------------------------------------------------------------
# API (.NET) — passed through docker-compose environment
# -----------------------------------------------------------------------------
# H.264 relay hint for simulator / ingest (API reads MediaMtx__H264RelayEnabled)
MEDIAMTX_H264_RELAY_ENABLED=true
# In-container simulator URL (compose sets Simulator__ApiBaseUrl)
# SIMULATOR_API_BASE_URL=http://omni-simulator:8554
# Enable PATCH /api/integration/env from UI Settings (hackathon; disable in prod)
OMNI_ENV_EDITOR_ENABLED=true

# -----------------------------------------------------------------------------
# Host Ports (Exposed to host machine)
# -----------------------------------------------------------------------------
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8080
SIMULATOR_PORT=8554
# Start every video as RTSP→MediaMTX at container boot (default: manual “Generate stream” in UI)
OMNI_SIMULATOR_AUTOSTART=false
OBJECT_PORT=8555
VEHICLE_PORT=8001
HUMAN_PORT=8002
UI_PORT=3000

# -----------------------------------------------------------------------------
# Docker Compose data dirs (optional — override in compose if not using D: drive)
# Default compose file may use Windows paths; use named volumes on Linux/Mac.
# -----------------------------------------------------------------------------

DB_CONNECTION_STRING=Host=omni-db;Database=omnivision;Username=postgres;Password=admin
REDIS_CONNECTION_STRING=omni-bus:6379,abortConnect=false

# Inside Docker network the API uses this for MediaMTX config API (set in compose):
# MediaMtx__ApiBaseUrl=http://omni-mediamtx:8997
